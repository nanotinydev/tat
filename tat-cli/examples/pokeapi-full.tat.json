{
  "$schema": "https://unpkg.com/tiny-api-test/schema.json",
  "env": {
    "baseUrl": "https://pokeapi.co/api/v2"
  },
  "suites": [
    {
      "name": "Pokemon",
      "tags": ["smoke", "pokemon"],
      "tests": [
        {
          "name": "GET /pokemon list returns paginated results",
          "method": "GET",
          "url": "{{baseUrl}}/pokemon?limit=10",
          "assert": ["$status == 200", "count is not null", "results is not null"]
        },
        {
          "name": "GET /pokemon/pikachu returns Pikachu by name",
          "method": "GET",
          "url": "{{baseUrl}}/pokemon/pikachu",
          "assert": [
            "$status == 200",
            "id == 25",
            "name == 'pikachu'",
            "base_experience is not null",
            "height is not null",
            "weight is not null",
            "abilities is not null",
            "moves is not null",
            "types is not null",
            "stats is not null",
            "sprites is not null"
          ],
          "capture": {
            "pikachuId": "id",
            "pikachuType": "types.type.name",
            "hpStat": "stats.base_stat | $index == 0",
            "speedStat": "stats.base_stat | $index == 5"
          }
        },
        {
          "name": "GET /pokemon/1 returns Bulbasaur by ID",
          "method": "GET",
          "url": "{{baseUrl}}/pokemon/1",
          "assert": [
            "$status == 200",
            "id == 1",
            "name == 'bulbasaur'"
          ]
        },
        {
          "name": "GET /pokemon/{{pikachuId}} matches Pikachu ID from capture",
          "method": "GET",
          "url": "{{baseUrl}}/pokemon/{{pikachuId}}",
          "assert": ["$status == 200", "name == 'pikachu'"]
        },
        {
          "name": "GET /pokemon/9999999 returns 404 for unknown pokemon",
          "method": "GET",
          "url": "{{baseUrl}}/pokemon/9999999",
          "assert": ["$status == 404"]
        }
      ]
    },
